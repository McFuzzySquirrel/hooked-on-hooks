{
  "version": 1,
  "description": "Minimal vanilla hooks — logs raw Copilot CLI payloads with no transformations.",
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./.github/hooks/session-start.sh",
        "powershell": "./.github/hooks/session-start.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./.github/hooks/session-end.sh",
        "powershell": "./.github/hooks/session-end.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./.github/hooks/log-prompt.sh",
        "powershell": "./.github/hooks/log-prompt.ps1",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./.github/hooks/pre-tool-use.sh",
        "powershell": "./.github/hooks/pre-tool-use.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./.github/hooks/post-tool-use.sh",
        "powershell": "./.github/hooks/post-tool-use.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "./.github/hooks/agent-stop.sh",
        "powershell": "./.github/hooks/agent-stop.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "./.github/hooks/subagent-stop.sh",
        "powershell": "./.github/hooks/subagent-stop.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./.github/hooks/error-occurred.sh",
        "powershell": "./.github/hooks/error-occurred.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
